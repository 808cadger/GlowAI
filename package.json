{
  "name": "glowai",
  "version": "1.0.0",
  "description": "GlowAI — AI skin analysis & appointments",
  "scripts": {
    "build": "esbuild www/scan.js --bundle --outfile=www/scan.bundle.js --platform=browser --target=es2020 --minify",
    "build:dev": "esbuild www/scan.js --bundle --outfile=www/scan.bundle.js --platform=browser --target=es2020",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && cd android && ./gradlew assembleDebug",
    "deploy": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  }
}
