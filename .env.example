# GlowAI — copy to .env and fill in your values
# AI provider priority: ANTHROPIC_API_KEY → GROQ_API_KEY → Ollama local

# Required
API_TOKEN=change-me-generate-with-python3-secrets-token_urlsafe-32
DATABASE_URL=sqlite+aiosqlite:///./glowai.db

# AI — pick at least one
ANTHROPIC_API_KEY=
GROQ_API_KEY=                        # free tier at console.groq.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=moondream
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Optional
CORS_ORIGINS=http://localhost:3000,http://localhost,capacitor://localhost
PORT=8000

# Stripe — only needed for freemium/salon payments
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREEMIUM_UNLOCK=
STRIPE_PRICE_SALON_MONTHLY=
STRIPE_SUCCESS_URL=https://808cadger.github.io/GlowAI/download.html?checkout=success
STRIPE_CANCEL_URL=https://808cadger.github.io/GlowAI/download.html?checkout=cancelled
